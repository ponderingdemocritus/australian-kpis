{
  "openapi": "3.1.0",
  "info": {
    "title": "Australian KPIs API",
    "description": "Unified API for Australian public economic data.",
    "license": {
      "name": "Apache-2.0",
      "identifier": "Apache-2.0"
    },
    "version": "0.1.0"
  },
  "paths": {
    "/v1/health": {
      "get": {
        "tags": [],
        "summary": "`GET /v1/health`.",
        "operationId": "health",
        "responses": {
          "200": {
            "description": "API is healthy.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthResponse"
                }
              }
            }
          },
          "408": {
            "description": "Request timed out.",
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          }
        }
      }
    },
    "/v1/openapi.json": {
      "get": {
        "tags": [],
        "summary": "`GET /v1/openapi.json`.",
        "operationId": "openapi",
        "responses": {
          "200": {
            "description": "Current OpenAPI document.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          },
          "408": {
            "description": "Request timed out.",
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          },
          "500": {
            "description": "OpenAPI generation failed.",
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "HealthResponse": {
        "type": "object",
        "description": "Health endpoint response.",
        "required": ["status"],
        "properties": {
          "status": {
            "type": "string",
            "description": "Current service health."
          }
        }
      },
      "ProblemDetails": {
        "type": "object",
        "description": "RFC 7807 problem details body.",
        "required": ["type", "title", "status"],
        "properties": {
          "detail": {
            "type": ["string", "null"],
            "description": "Request-specific detail, if any."
          },
          "instance": {
            "type": ["string", "null"],
            "description": "Resource-specific identifier, if any."
          },
          "status": {
            "type": "integer",
            "format": "int32",
            "description": "HTTP status code for this problem.",
            "minimum": 0
          },
          "title": {
            "type": "string",
            "description": "Short, human-readable summary."
          },
          "type": {
            "type": "string",
            "description": "Problem type URI."
          }
        }
      }
    }
  }
}
