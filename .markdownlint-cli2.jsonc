{
  "gitignore": true,
  "globs": ["**/*.md"],
  "ignores": [".context/**", "target/**"],
  "config": {
    "default": true,
    "line-length": false,
    "blanks-around-headings": false,
    "blanks-around-fences": false,
    "blanks-around-lists": false,
    "fenced-code-language": false,
    "first-line-heading": false,
    "no-emphasis-as-heading": false,
    "no-duplicate-heading": {
      "siblings_only": true
    }
  }
}
